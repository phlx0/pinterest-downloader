{
  "manifest_version": 3,
  "name": "Pinterest HD Downloader",
  "version": "1.0.0",
  "description": "Download Pinterest images and videos in the highest resolution with one click.",
  "author": "phlx0",

  "permissions": ["downloads"],
  "host_permissions": ["*://*.pinterest.com/*", "*://i.pinimg.com/*"],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["*://*.pinterest.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": "icons/icon48.png",
    "default_popup": "popup.html",
    "default_title": "Pinterest HD Downloader"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "pinterest-downloader@phlx0",
      "strict_min_version": "109.0",
      "data_collection_permissions": []
    }
  }
}
